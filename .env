# ======================================
# CONFIGURACIÓN DE BASE DE DATOS POSTGRESQL (RENDER)
# ======================================

# Render proporcionará estos valores automáticamente
# En desarrollo local, usa estos valores por defecto:

# Host de PostgreSQL (Render proporciona automáticamente)
DB_HOST=localhost

# Usuario de PostgreSQL
DB_USER=postgres

# Contraseña de PostgreSQL
DB_PASSWORD=postgres

# Nombre de la base de datos
DB_NAME=siee_db

# Puerto de PostgreSQL (5432 es el default)
DB_PORT=5432

# ======================================
# CONFIGURACIÓN DE FLASK
# ======================================

# Activar modo debug (cambiar a 0 en producción)
FLASK_DEBUG=0

# Clave secreta (generada automáticamente si no está)
# SECRET_KEY=tu_clave_secreta_aqui
