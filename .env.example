# ======================================
# CONFIGURACIÓN DE BASE DE DATOS MYSQL
# ======================================

# Host de MySQL (localhost para desarrollo)
DB_HOST=localhost

# Usuario de MySQL
DB_USER=root

# Contraseña de MySQL
DB_PASSWORD=root

# Nombre de la base de datos
DB_NAME=siee_db

# Puerto de MySQL (3306 es el default)
DB_PORT=3306

# ======================================
# CONFIGURACIÓN DE FLASK
# ======================================

# Activar modo debug (cambiar a 0 en producción)
FLASK_DEBUG=0

# Clave secreta (generada automáticamente si no está)
# SECRET_KEY=tu_clave_secreta_aqui
